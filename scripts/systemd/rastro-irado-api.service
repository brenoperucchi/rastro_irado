[Unit]
Description=IRAI API (FastAPI/uvicorn :8888, WSL)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/brenoperucchi/Devs/rastro_irado
ExecStart=/home/brenoperucchi/Devs/rastro_irado/scripts/systemd/api-wsl.sh
Restart=on-failure
RestartSec=5
Environment=IRAI_PYTHON=/mnt/c/Users/brenoperucchi/AppData/Local/Microsoft/WindowsApps/py.exe
Environment=IRAI_PYTHON_VERSION_FLAG=-3.12
Environment=IRAI_API_PORT=8888

[Install]
WantedBy=default.target
