[Unit]
Description=IRAI frontend Vite (:5175)
After=network-online.target rastro-irado-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@RUNTIME_ROOT@
ExecStart=/usr/bin/npm --prefix @RUNTIME_ROOT@/frontend run dev -- --host 0.0.0.0 --port 5175 --strictPort
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
